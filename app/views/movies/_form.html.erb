<%= form_with model: movie do |form| %>
    <% if form.object.errors.any? %>
        <div>
            <% form.object.errors.full_messages.each do |message| %>
                <div><%= message %></div>
            <% end %>
        </div>
    <% end %>
    <div class='form'>
        <div>
            <%= form.label :title %>
            <%= form.text_field :title %>
        </div>
        
        <div>
            <%= form.label :year_watched %>
            <%= form.text_field :year_watched %>
        </div>


        <div>
            <%= form.label :year_released %>
            <%= form.text_field :year_released %>
        </div>

        <div>
            <%= form.label :genre %>
            <%= form.text_field :genre %>
        </div>
        
        <div>
            <%= form.label :place %>
            <%= form.text_field :place %>
        </div>

        <div>
            <%= form.label :rewatch %>
            <%= form.text_field :rewatch %>
        </div>

        <%= form.button %>
    </div>
<% end%>

<%# t.string :title
      t.integer :year_watched
      t.integer :year_released
      t.string :genre
      t.integer :place
      t.boolean :rewatch %>